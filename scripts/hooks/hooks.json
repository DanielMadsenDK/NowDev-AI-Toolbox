{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/block-non-node-scripts.js",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/session-summary.js",
        "timeout": 15
      }
    ]
  }
}

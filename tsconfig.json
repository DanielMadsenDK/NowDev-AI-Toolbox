{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "outDir": "out",
    "rootDir": "src",
    "lib": ["es2020", "dom"],
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0"
  },
